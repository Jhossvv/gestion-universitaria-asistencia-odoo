<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_asistencia_registro_tree" model="ir.ui.view">
        <field name="name">asistencia.registro.tree</field>
        <field name="model">asistencia.registro</field>
        <field name="arch" type="xml">
            <tree string="Registros de Asistencia">
                <field name="name"/>
                <field name="materia_id"/>
                <field name="fecha"/>
            </tree>
        </field>
    </record>

    <record id="view_asistencia_registro_form" model="ir.ui.view">
        <field name="name">asistencia.registro.form</field>
        <field name="model">asistencia.registro</field>
        <field name="arch" type="xml">
            <form string="Registro de Asistencia">
                <header>
                    <button name="accion_cargar_estudiantes" 
                            string="Cargar Estudiantes Inscritos" 
                            type="object" 
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="Descripción de la Clase"/>
                        <h1>
                            <field name="name" placeholder="Ej. Clase de Programación - Unidad 1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="materia_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="seccion_univ_id" widget="selection"    />
                        </group>
                        <group>
                            <field name="fecha"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Listado de Asistencia Estudiantil" name="page_lineas_asistencia">
                            <field name="linea_ids">
                                <tree editable="bottom" create="false">
                                    <field name="estudiante_id" readonly="1"/>
                                    <field name="estado" widget="radio" options="{'horizontal': true}"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_asistencia_registro_main" model="ir.actions.act_window">
        <field name="name">Control de Asistencias</field>
        <field name="res_model">asistencia.registro</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crea un nuevo registro de asistencia.
            </p>
            <p>
                Selecciona la materia, la fecha y presiona "Cargar Estudiantes" para pasar la lista.
            </p>
        </field>
    </record>

    <menuitem id="menu_asistencia_raiz" name="Asistencias" sequence="10"/>
    <menuitem id="menu_asistencia_registro" name="Diario de Asistencia" parent="menu_asistencia_raiz" action="action_asistencia_registro_main"/>

</odoo>
